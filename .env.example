# Shopify store (your-store.myshopify.com — domain only, no https://)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2026-01

# Admin API — used by `npm run sync:shopify` to push products & collections
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxx

# Storefront API — used by Next.js to read catalog at runtime
SHOPIFY_STOREFRONT_ACCESS_TOKEN=xxxxxxxx

# Production: set to false to disable local JSON fallback when Shopify is configured
SHOPIFY_USE_STATIC_FALLBACK=false

# Optional webhook secret for /api/webhooks/shopify
SHOPIFY_WEBHOOK_SECRET=

# External image CDN (S3 or CloudFront in front of S3)
# /images/brands/foo.png  → https://cdn.example.com/upload/brands/foo.png
# /images/sell/samsung/x  → https://cdn.example.com/upload/sell/samsung/x
IMAGE_CDN_BASE_URL=https://cdn.yourdomain.com
# Set true when the CDN/S3 bucket allows public reads. false uses 4gadgets media as fallback.
IMAGE_CDN_PUBLIC=false
# Optional override for image fallback origin (default: https://www.4gadgets.co.uk)
# IMAGE_FALLBACK_ORIGIN=https://www.4gadgets.co.uk

# Optional fallback when IMAGE_CDN_BASE_URL is not set during sync
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — trade-in submissions only (not catalog)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: Database URI for `npm run supabase:migrate` (Settings → Database → Connection string)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Admin dashboard (/admin/trade-ins)
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=change-me
# Generate each of these separately: openssl rand -base64 32
ADMIN_SESSION_SECRET=generate-a-long-random-string
# Signs customer login cookies. Falls back to ADMIN_SESSION_SECRET if unset —
# set it properly so customer and admin sessions don't share one secret.
CUSTOMER_SESSION_SECRET=
# Hashes issued gift-card codes so they're never stored in plain text.
# Changing it later makes existing codes unredeemable, so set it before launch.
GIFT_CARD_HASH_SECRET=

# Email (optional). When unset, emails are skipped and logged instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="4gadgets <no-reply@4gadgets.co.uk>"
# Overrides the default shipping instructions; supports {{submissionId}}
TRADE_IN_SHIPPING_INSTRUCTIONS=

# PayPal Payouts. sandbox|live. Leave unset to disable the PayPal rail.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Testing only: sandbox personal account that receives payouts.
PAYPAL_SANDBOX_RECEIVER_EMAIL=

# Store credit bonus added when the customer picks Store Credit (default 15).
# NEXT_PUBLIC_ so checkout can display it; the server still recomputes the total.
NEXT_PUBLIC_TRADE_IN_STORE_CREDIT_BONUS=15
# PayPal webhook id (Apps & Credentials -> your app -> Webhooks). Required for
# /api/webhooks/paypal — unverified payout webhooks are rejected.
PAYPAL_WEBHOOK_ID=

# Default resale markup for refurb units on accept: max(cost*(1+PCT/100), cost+GBP).
REFURB_DEFAULT_MARKUP_PCT=30
REFURB_DEFAULT_MARKUP_GBP=10

# Authorises the scheduled job that releases stock from unpaid orders
# (/api/cron/release-abandoned). Vercel Cron sends it as a Bearer token.
CRON_SECRET=

# How long an unpaid order holds its stock before the device is released.
# BUY_PAYPAL_ABANDON_MINUTES=60
# BUY_BANK_ABANDON_HOURS=120

# Bank details shown to the customer when they choose bank transfer.
BUY_BANK_ACCOUNT_NAME=
BUY_BANK_SORT_CODE=
BUY_BANK_ACCOUNT_NUMBER=
